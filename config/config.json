{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "demoweb-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/demoweb/DemowebWebPart.js",
          "manifest": "./src/webparts/demoweb/DemowebWebPart.manifest.json"
        }
      ]
    },
    "learner-blog-post-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/learnerBlogPost/LearnerBlogPostWebPart.js",
          "manifest": "./src/webparts/learnerBlogPost/LearnerBlogPostWebPart.manifest.json"
        }
      ]
    },
    "marketing-calendar-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/marketingCalendar/MarketingCalendarWebPart.js",
          "manifest": "./src/webparts/marketingCalendar/MarketingCalendarWebPart.manifest.json"
        }
      ]
    },
    "posts-archive-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/postsArchive/PostsArchiveWebPart.js",
          "manifest": "./src/webparts/postsArchive/PostsArchiveWebPart.manifest.json"
        }
      ]
    },
    "consolidated-calendar-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/consolidatedCalendar/ConsolidatedCalendarWebPart.js",
          "manifest": "./src/webparts/consolidatedCalendar/ConsolidatedCalendarWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "DemowebWebPartStrings": "lib/webparts/demoweb/loc/{locale}.js",
    "ControlStrings": "node_modules/@pnp/spfx-controls-react/lib/loc/{locale}.js",
    "LearnerBlogPostWebPartStrings": "lib/webparts/learnerBlogPost/loc/{locale}.js",
    "MarketingCalendarWebPartStrings": "lib/webparts/marketingCalendar/loc/{locale}.js",
    "PostsArchiveWebPartStrings": "lib/webparts/postsArchive/loc/{locale}.js",
    "ConsolidatedCalendarWebPartStrings": "lib/webparts/consolidatedCalendar/loc/{locale}.js"
  }
}
